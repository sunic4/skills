{
  "name": "@sunic/skills-apifox-cli",
  "version": "1.0.1",
  "description": "Apifox CLI tool for importing and exporting OpenAPI/Postman data",
  "main": "dist/index.js",
  "bin": {
    "apifox": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx ./src/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --outdir=dist --external:better-sqlite3 --external:kysely --format=cjs --minify",
    "start": "node dist/index.js",
    "debug": "node --inspect dist/index.js",
    "prepublish": "npm run build",
    "pub": "npm run build & npm publish"
  },
  "keywords": [
    "apifox",
    "cli",
    "openapi",
    "swagger",
    "postman"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "commander": "^11.1.0",
    "kysely": "^0.28.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}